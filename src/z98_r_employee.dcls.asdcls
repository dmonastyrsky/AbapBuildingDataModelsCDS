@EndUserText.label: 'Employee (Access Control)'
@MappingRole: true
define role Z98_R_EMPLOYEE {
    grant 
        select
            on
                Z98_R_EMPLOYEE
                    where (DepartmentId ) 
      = aspect pfcg_auth(
                  Z98DPMNT, 
                  Z98DPMNT,                  
                  ACTVT = '03'
               )
               /* Temporary bypass: allow all records for testing purposes */ 
               or true;  
}